# Virtual environment
.venv/

# Input / output content (keep directories, ignore files)
input/*
output/*
!input/.gitkeep
!output/.gitkeep

# JSON directory (local settings)
JSON/

# macOS
.DS_Store

# Python
__pycache__/
*.pyc

# Claude Code local settings
.claude/settings.local.json

# Hardware config (machine-specific, auto-generated on first run)
.mlx-config

# Local glossary (personal use, see local/glossary.example.txt for format)
local/glossary.txt
local/glossary_candidates.txt
