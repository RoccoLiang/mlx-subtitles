#!/bin/bash
# transcribe - Generate English subtitles (.words.json + .en.srt) using mlx-whisper
#
# Usage:
#   ./transcribe                    # process all videos in input/
#   ./transcribe video.mp4          # process a single file
#   ./transcribe video.mp4 medium   # specify model size
#
# Models: large-v3 (default), large-v3-turbo, medium, small

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_DIR="$SCRIPT_DIR/.venv"
PYTHON="$VENV_DIR/bin/python"

# ── Environment setup ──────────────────────────────────────────────────────────

setup_env() {
    # 1. Check uv
    if ! command -v uv &>/dev/null; then
        echo "ERROR: uv not found."
        echo "Install with: curl -LsSf https://astral.sh/uv/install.sh | sh"
        exit 1
    fi

    # 2. Remove incompatible venv (e.g. synced from another machine)
    if [ -d "$VENV_DIR" ] && [ ! -x "$PYTHON" ]; then
        echo "Removing incompatible virtual environment..."
        rm -rf "$VENV_DIR"
    fi

    # 3. Create venv if missing
    if [ ! -d "$VENV_DIR" ]; then
        echo "Creating virtual environment..."
        uv venv "$VENV_DIR"
    fi

    # 4. Install packages
    echo "Installing packages (~200 MB, model weights will download on first transcription)..."
    uv pip install --python "$VENV_DIR" -r "$SCRIPT_DIR/requirements.txt"

    echo ""
    echo "✓ Environment ready"
    echo ""
}

# ── Check environment ──────────────────────────────────────────────────────────

# Python binary missing or broken (dead symlink)?
if [ ! -x "$PYTHON" ]; then
    echo "Setting up environment..."
    setup_env
fi

# Packages importable?
if ! "$PYTHON" -c "import mlx_whisper" 2>/dev/null; then
    echo "Packages missing, installing..."
    uv pip install --python "$VENV_DIR" -r "$SCRIPT_DIR/requirements.txt"
    echo ""
fi

# ── Run ────────────────────────────────────────────────────────────────────────

ARGS=()

case $# in
    0) ;;
    1) ARGS=(--file "$1") ;;
    2) ARGS=(--file "$1" --model "$2") ;;
    *) echo "Usage: transcribe [video_file] [model]"; exit 1 ;;
esac

exec "$PYTHON" "$SCRIPT_DIR/scripts/generate_subtitles.py" "${ARGS[@]}"
